<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== Color Palette ===== -->
    <SolidColorBrush x:Key="ColorRootBg" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="ColorSidePanel" Color="#202020"/>
    <SolidColorBrush x:Key="ColorSurface" Color="#242424"/>
    <SolidColorBrush x:Key="ColorNavBg" Color="#202020"/>
    <SolidColorBrush x:Key="ColorConsoleBg" Color="#101010"/>
    <SolidColorBrush x:Key="ColorButtonBg" Color="#333333"/>
    <SolidColorBrush x:Key="ColorButtonBorder" Color="#555555"/>
    <SolidColorBrush x:Key="ColorSurfaceBorder" Color="#3A3A3A"/>
    <SolidColorBrush x:Key="ColorTextBoxBg" Color="#2B2B2B"/>
    <SolidColorBrush x:Key="ColorListBoxBg" Color="#151515"/>
    <SolidColorBrush x:Key="ColorGridLine" Color="#333333"/>
    <SolidColorBrush x:Key="ColorHeaderRow" Color="#303030"/>
    <SolidColorBrush x:Key="ColorTextPrimary" Color="White"/>
    <SolidColorBrush x:Key="ColorTextDim" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="ColorSwitchOffBg" Color="#4A4A4A"/>
    <SolidColorBrush x:Key="ColorSwitchOnBg" Color="#2EAA5F"/>

    <!-- ===== Implicit Button ===== -->
    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ColorButtonBg}"/>
        <Setter Property="Foreground" Value="{StaticResource ColorTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ColorButtonBorder}"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Margin" Value="3"/>
    </Style>

    <Style x:Key="CommunicationToolBar" TargetType="ToolBar">
        <Setter Property="Background" Value="#252525"/>
    </Style>

    <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{StaticResource ColorNavBg}"/>
        <Setter Property="Foreground" Value="{StaticResource ColorTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ColorGridLine}"/>
        <Setter Property="Height" Value="70"/>
        <Setter Property="Padding" Value="8,5"/>
        <Setter Property="Margin" Value="0"/>
    </Style>

    <Style x:Key="NavButton" TargetType="Button" BasedOn="{StaticResource IconButton}"/>

    <Style x:Key="NavIconText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource ColorTextPrimary}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="NavLabelText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource ColorTextPrimary}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,4,0,0"/>
    </Style>

    <Style x:Key="SectionSubtitle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="0,10,0,6"/>
        <Setter Property="Foreground" Value="{StaticResource ColorTextPrimary}"/>
    </Style>

    <Style x:Key="SectionHeaderText" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
        <Setter Property="Foreground" Value="{StaticResource ColorTextPrimary}"/>
    </Style>

    <Style x:Key="PanelHeaderText" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource ColorTextPrimary}"/>
    </Style>

    <Style x:Key="SectionDivider" TargetType="Border">
        <Setter Property="Height" Value="1"/>
        <Setter Property="Background" Value="{StaticResource ColorHeaderRow}"/>
        <Setter Property="Margin" Value="0,14,0,12"/>
    </Style>

    <Style x:Key="EditorPageTitle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="Foreground" Value="#E6E6E6"/>
        <Setter Property="FontSize" Value="17"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <Style x:Key="EditorPlaceholderText" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="Foreground" Value="Gray"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Margin" Value="0,12,0,0"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="TextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="ConfigFieldRow" TargetType="DockPanel">
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>

    <Style x:Key="ConfigFieldLabel" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="Width" Value="110"/>
        <Setter Property="Margin" Value="0,0,12,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="{StaticResource ColorTextDim}"/>
    </Style>

    <Style x:Key="FormFieldLabelText" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="Margin" Value="0,0,12,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="{StaticResource ColorTextDim}"/>
    </Style>

    <Style x:Key="TableHeaderText" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="#AAAAAA"/>
        <Setter Property="Margin" Value="4,0,0,0"/>
    </Style>

    <Style x:Key="TableHeaderTextLeading" TargetType="TextBlock" BasedOn="{StaticResource TableHeaderText}">
        <Setter Property="Margin" Value="0"/>
    </Style>

    <!-- ===== Implicit TextBox ===== -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource ColorTextBoxBg}"/>
        <Setter Property="Foreground" Value="{StaticResource ColorTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ColorButtonBorder}"/>
        <Setter Property="Padding" Value="5,3"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style x:Key="FormValueTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="Height" Value="28"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="MinWidth" Value="280"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>

    <!-- ===== Implicit TextBlock ===== -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource ColorTextDim}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ===== Implicit ListBox ===== -->
    <Style TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource ColorListBoxBg}"/>
        <Setter Property="Foreground" Value="{StaticResource ColorTextPrimary}"/>
        <Setter Property="BorderBrush" Value="#444444"/>
    </Style>
    <Style TargetType="ListBoxItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- ===== Implicit ComboBox ===== -->
    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource ColorTextPrimary}"/>
        <Setter Property="Foreground" Value="{StaticResource ColorTextBoxBg}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ColorButtonBorder}"/>
        <Setter Property="Padding" Value="5,3"/>
        <Setter Property="IsSynchronizedWithCurrentItem" Value="False"/>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CompactComboBox" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
        <Setter Property="Height" Value="34"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="LightComboBox" TargetType="ComboBox">
        <Style.Resources>
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="Black"/>
            </Style>
        </Style.Resources>
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="TextElement.Foreground" Value="Black"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="TextElement.Foreground" Value="Black"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="BindingSelectorCombo" TargetType="ComboBox" BasedOn="{StaticResource LightComboBox}">
        <Setter Property="MinWidth" Value="280"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>

    <Style x:Key="ActionButtonSmall" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Height" Value="28"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="10,3"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="SectionCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ColorSurface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ColorButtonBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12"/>
        <Setter Property="Margin" Value="0,12,0,0"/>
        <Setter Property="CornerRadius" Value="4"/>
    </Style>

    <Style x:Key="SwitchButton" TargetType="ToggleButton">
        <Setter Property="Background" Value="{StaticResource ColorSwitchOffBg}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Track" Width="42" Height="24" Background="{TemplateBinding Background}" CornerRadius="12">
                        <Ellipse x:Name="Thumb" Width="20" Height="20" Fill="White" HorizontalAlignment="Left" Margin="2"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="{StaticResource ColorSwitchOnBg}"/>
                            <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DeviceToggle" TargetType="ToggleButton" BasedOn="{StaticResource SwitchButton}"/>

    <!-- ===== Implicit CheckBox / RadioButton ===== -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource ColorTextPrimary}"/>
    </Style>
    <Style TargetType="RadioButton">
        <Setter Property="Foreground" Value="{StaticResource ColorTextPrimary}"/>
    </Style>

    <!-- ===== DataGrid ===== -->
    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{StaticResource ColorRootBg}"/>
        <Setter Property="Foreground" Value="{StaticResource ColorTextPrimary}"/>
        <Setter Property="RowBackground" Value="{StaticResource ColorSurface}"/>
        <Setter Property="AlternatingRowBackground" Value="{StaticResource ColorSidePanel}"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource ColorGridLine}"/>
        <Setter Property="BorderBrush" Value="#444444"/>
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="Foreground" Value="{StaticResource ColorTextPrimary}"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource ColorHeaderRow}"/>
        <Setter Property="Foreground" Value="{StaticResource ColorTextPrimary}"/>
    </Style>

    <DataTemplate x:Key="BlockItemTemplate">
        <Border Background="{StaticResource ColorSurface}" BorderBrush="#3A3A3A" BorderThickness="1" Padding="10" Margin="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource ColorTextPrimary}" FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock Text="{Binding Address}" Foreground="#9A9A9A" FontSize="11" Margin="0,3,0,0"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="{Binding DataType}" Foreground="{StaticResource ColorTextDim}" FontSize="11"/>
                        <TextBlock Text="  |  " Foreground="#666666" FontSize="11"/>
                        <TextBlock Text="{Binding PollingEnabled, StringFormat=轮询: {0}}" Foreground="{StaticResource ColorTextDim}" FontSize="11"/>
                        <TextBlock Text="  |  " Foreground="#666666" FontSize="11"/>
                        <TextBlock Text="{Binding PollingIntervalMs, StringFormat=周期: {0}ms}" Foreground="{StaticResource ColorTextDim}" FontSize="11"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </DataTemplate>

</ResourceDictionary>
