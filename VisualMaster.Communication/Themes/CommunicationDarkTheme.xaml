<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== Color Palette ===== -->
    <Color x:Key="ColorRootBg">#1E1E1E</Color>
    <Color x:Key="ColorSidePanel">#202020</Color>
    <Color x:Key="ColorSurface">#242424</Color>
    <Color x:Key="ColorButtonBg">#333333</Color>
    <Color x:Key="ColorButtonBorder">#555555</Color>
    <Color x:Key="ColorTextBoxBg">#2B2B2B</Color>
    <Color x:Key="ColorListBoxBg">#151515</Color>
    <Color x:Key="ColorGridLine">#333333</Color>
    <Color x:Key="ColorHeaderRow">#303030</Color>
    <Color x:Key="ColorTextPrimary">White</Color>
    <Color x:Key="ColorTextDim">#CCCCCC</Color>

    <!-- ===== Implicit Button ===== -->
    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ColorButtonBg}"/>
        <Setter Property="Foreground" Value="{StaticResource ColorTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ColorButtonBorder}"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Margin" Value="3"/>
    </Style>

    <!-- ===== Implicit TextBox ===== -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource ColorTextBoxBg}"/>
        <Setter Property="Foreground" Value="{StaticResource ColorTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ColorButtonBorder}"/>
        <Setter Property="Padding" Value="5,3"/>
    </Style>

    <!-- ===== Implicit TextBlock ===== -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource ColorTextDim}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ===== Implicit ListBox ===== -->
    <Style TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource ColorListBoxBg}"/>
        <Setter Property="Foreground" Value="{StaticResource ColorTextPrimary}"/>
        <Setter Property="BorderBrush" Value="#444444"/>
    </Style>

    <!-- ===== Implicit ComboBox ===== -->
    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource ColorTextBoxBg}"/>
        <Setter Property="Foreground" Value="{StaticResource ColorTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ColorButtonBorder}"/>
        <Setter Property="Padding" Value="5,3"/>
    </Style>

    <!-- ===== Implicit CheckBox ===== -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource ColorTextPrimary}"/>
    </Style>

    <!-- ===== DataGrid ===== -->
    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{StaticResource ColorRootBg}"/>
        <Setter Property="Foreground" Value="{StaticResource ColorTextPrimary}"/>
        <Setter Property="RowBackground" Value="{StaticResource ColorSurface}"/>
        <Setter Property="AlternatingRowBackground" Value="{StaticResource ColorSidePanel}"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource ColorGridLine}"/>
        <Setter Property="BorderBrush" Value="#444444"/>
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="Foreground" Value="{StaticResource ColorTextPrimary}"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource ColorHeaderRow}"/>
        <Setter Property="Foreground" Value="{StaticResource ColorTextPrimary}"/>
    </Style>

</ResourceDictionary>
