<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== Color Palette ===== -->
    <SolidColorBrush x:Key="ColorRootBg" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="ColorSidePanel" Color="#202020"/>
    <SolidColorBrush x:Key="ColorSurface" Color="#242424"/>
    <SolidColorBrush x:Key="ColorButtonBg" Color="#333333"/>
    <SolidColorBrush x:Key="ColorButtonBorder" Color="#555555"/>
    <SolidColorBrush x:Key="ColorTextBoxBg" Color="#2B2B2B"/>
    <SolidColorBrush x:Key="ColorListBoxBg" Color="#151515"/>
    <SolidColorBrush x:Key="ColorGridLine" Color="#333333"/>
    <SolidColorBrush x:Key="ColorHeaderRow" Color="#303030"/>
    <SolidColorBrush x:Key="ColorTextPrimary" Color="White"/>
    <SolidColorBrush x:Key="ColorTextDim" Color="#CCCCCC"/>

    <!-- ===== Implicit Button ===== -->
    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ColorButtonBg}"/>
        <Setter Property="Foreground" Value="{StaticResource ColorTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ColorButtonBorder}"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Margin" Value="3"/>
    </Style>

    <!-- ===== Implicit TextBox ===== -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource ColorTextBoxBg}"/>
        <Setter Property="Foreground" Value="{StaticResource ColorTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ColorButtonBorder}"/>
        <Setter Property="Padding" Value="5,3"/>
    </Style>

    <!-- ===== Implicit TextBlock ===== -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource ColorTextDim}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ===== Implicit ListBox ===== -->
    <Style TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource ColorListBoxBg}"/>
        <Setter Property="Foreground" Value="{StaticResource ColorTextPrimary}"/>
        <Setter Property="BorderBrush" Value="#444444"/>
    </Style>

    <!-- ===== Implicit ComboBox ===== -->
    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource ColorTextBoxBg}"/>
        <Setter Property="Foreground" Value="{StaticResource ColorTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ColorButtonBorder}"/>
        <Setter Property="Padding" Value="5,3"/>
    </Style>

    <!-- ===== Implicit CheckBox ===== -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource ColorTextPrimary}"/>
    </Style>

    <!-- ===== DataGrid ===== -->
    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{StaticResource ColorRootBg}"/>
        <Setter Property="Foreground" Value="{StaticResource ColorTextPrimary}"/>
        <Setter Property="RowBackground" Value="{StaticResource ColorSurface}"/>
        <Setter Property="AlternatingRowBackground" Value="{StaticResource ColorSidePanel}"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource ColorGridLine}"/>
        <Setter Property="BorderBrush" Value="#444444"/>
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="Foreground" Value="{StaticResource ColorTextPrimary}"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource ColorHeaderRow}"/>
        <Setter Property="Foreground" Value="{StaticResource ColorTextPrimary}"/>
    </Style>

</ResourceDictionary>
