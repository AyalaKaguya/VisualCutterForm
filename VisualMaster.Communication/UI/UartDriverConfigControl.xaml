<UserControl x:Class="VisualMaster.Communication.UI.UartDriverConfigControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ColorRootBg}"
             Foreground="White"
             FontSize="15">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/CommunicationDarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                <Setter Property="Height" Value="34"/>
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="128"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="128"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="48"/>
            <RowDefinition Height="48"/>
            <RowDefinition Height="48"/>
            <RowDefinition Height="48"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.ColumnSpan="4" Text="UART 串口驱动" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,12"/>

        <TextBlock Grid.Row="1" Text="COM 端口"/>
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ComboBox x:Name="PortBox" IsEditable="True"
                      ItemsSource="{Binding AvailablePorts}"
                      Text="{Binding PortName, UpdateSourceTrigger=LostFocus}"/>
            <Button Grid.Column="1" Command="{Binding RefreshPortsCommand}"
                    Width="40" Height="34" Margin="6,0,0,0"
                    ToolTip="刷新可用串口" Content="↻"/>
        </Grid>

        <TextBlock Grid.Row="2" Text="波特率"/>
        <ComboBox x:Name="BaudBox" Grid.Row="2" Grid.Column="1" IsEditable="True"
                  Text="{Binding BaudRate, UpdateSourceTrigger=LostFocus}">
            <ComboBoxItem>9600</ComboBoxItem>
            <ComboBoxItem>19200</ComboBoxItem>
            <ComboBoxItem>38400</ComboBoxItem>
            <ComboBoxItem>57600</ComboBoxItem>
            <ComboBoxItem>115200</ComboBoxItem>
        </ComboBox>
        <TextBlock Grid.Row="2" Grid.Column="2" Text="数据位" Margin="16,0,0,0"/>
        <ComboBox x:Name="DataBitsBox" Grid.Row="2" Grid.Column="3" IsEditable="True"
                  Text="{Binding DataBits, UpdateSourceTrigger=LostFocus}">
            <ComboBoxItem>5</ComboBoxItem>
            <ComboBoxItem>6</ComboBoxItem>
            <ComboBoxItem>7</ComboBoxItem>
            <ComboBoxItem>8</ComboBoxItem>
        </ComboBox>

        <TextBlock Grid.Row="3" Text="Parity"/>
        <ComboBox x:Name="ParityBox" Grid.Row="3" Grid.Column="1" IsEditable="True"
                  Text="{Binding Parity, UpdateSourceTrigger=LostFocus}">
                <ComboBoxItem>None</ComboBoxItem>
                <ComboBoxItem>Odd</ComboBoxItem>
                <ComboBoxItem>Even</ComboBoxItem>
                <ComboBoxItem>Mark</ComboBoxItem>
                <ComboBoxItem>Space</ComboBoxItem>
        </ComboBox>
        <TextBlock Grid.Row="3" Grid.Column="2" Text="StopBits" Margin="16,0,0,0"/>
        <ComboBox x:Name="StopBitsBox" Grid.Row="3" Grid.Column="3" IsEditable="True"
                  Text="{Binding StopBits, UpdateSourceTrigger=LostFocus}">
                <ComboBoxItem>One</ComboBoxItem>
                <ComboBoxItem>Two</ComboBoxItem>
                <ComboBoxItem>OnePointFive</ComboBoxItem>
        </ComboBox>

        <TextBlock Grid.Row="4" Text="Handshake"/>
        <ComboBox x:Name="HandshakeBox" Grid.Row="4" Grid.Column="1" IsEditable="True"
                  Text="{Binding Handshake, UpdateSourceTrigger=LostFocus}">
            <ComboBoxItem>None</ComboBoxItem>
            <ComboBoxItem>XOnXOff</ComboBoxItem>
            <ComboBoxItem>RequestToSend</ComboBoxItem>
            <ComboBoxItem>RequestToSendXOnXOff</ComboBoxItem>
        </ComboBox>

        <Border Grid.Row="5" Grid.ColumnSpan="4" Background="#242424" BorderBrush="#444444" BorderThickness="1" Padding="10" Margin="0,14,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="128"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="绑定块名称"/>
                <TextBox x:Name="BlockNameBox" Grid.Column="1"
                         Text="{Binding BlockName, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Column="2" Content="实时" MinWidth="78" Height="34" FontSize="15" Margin="12,0,0,0" Click="OnRealtimeClick"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
