<Window x:Class="VisualMaster.Communication.UI.RawBytesMonitorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="通信监视"
        Width="560"
        Height="360"
        Background="#1E1E1E">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8">
            <RadioButton x:Name="HexMode" Content="HEX" Foreground="White" IsChecked="True" Margin="0,0,12,0"/>
            <RadioButton x:Name="ShortMode" Content="short" Foreground="White"/>
        </StackPanel>
        <TextBox x:Name="ValueBox"
                 Margin="8"
                 Background="#101010"
                 Foreground="#E6E6E6"
                 FontFamily="Consolas"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 IsReadOnly="True"/>
    </DockPanel>
</Window>
