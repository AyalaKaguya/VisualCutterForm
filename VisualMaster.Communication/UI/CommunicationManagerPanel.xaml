<UserControl x:Class="VisualMaster.Communication.UI.CommunicationManagerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E"
             Foreground="White">
    <UserControl.Resources>
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#303030"/>
            <Setter Property="Height" Value="70"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="70"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Background="#252525">
            <Button Style="{StaticResource NavButton}" Click="OnDevicesPage" ToolTip="设备管理">
                <StackPanel>
                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="18" HorizontalAlignment="Center"/>
                    <TextBlock Text="设备管理" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource NavButton}" Click="OnInputPage" ToolTip="输入事件">
                <StackPanel>
                    <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="18" HorizontalAlignment="Center"/>
                    <TextBlock Text="输入事件" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource NavButton}" Click="OnOutputPage" ToolTip="输出事件">
                <StackPanel>
                    <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="18" HorizontalAlignment="Center"/>
                    <TextBlock Text="输出事件" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource NavButton}" Click="OnHeartbeatPage" ToolTip="心跳">
                <StackPanel>
                    <TextBlock Text="&#xE95E;" FontFamily="Segoe MDL2 Assets" FontSize="18" HorizontalAlignment="Center"/>
                    <TextBlock Text="心跳" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Button>
        </StackPanel>
        <ContentControl x:Name="PageHost" Grid.Column="1"/>
    </Grid>
</UserControl>
