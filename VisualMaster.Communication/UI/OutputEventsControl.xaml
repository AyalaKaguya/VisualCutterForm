<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:VisualMaster.Communication.UI.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="VisualMaster.Communication.UI.OutputEventsControl"
             Background="{DynamicResource ColorRootBg}"
             Foreground="White"
             FontSize="15">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/CommunicationDarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{DynamicResource ColorRootBg}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <DockPanel Background="{DynamicResource ColorSidePanel}">
            <DockPanel DockPanel.Dock="Top" Margin="8">
                <TextBlock Text="输出事件" FontWeight="SemiBold"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="+" Width="30" Click="OnAddClick"/>
                </StackPanel>
            </DockPanel>
            <ListBox x:Name="EventList"
                     Margin="8"
                     SelectionChanged="OnEventSelected"
                     PreviewMouseRightButtonDown="OnListRightButtonDown" d:ItemsSource="{d:SampleData ItemCount=5}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="4,6">
                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                            <TextBlock FontSize="10" Foreground="#999999" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"
                                       Text="{Binding BindingInfo}"/>
                            <TextBlock FontSize="10" Foreground="#777777" Margin="0,1,0,0"><Run Text="变量: "/><Run Text="{Binding VariableCount, Mode=OneWay}"/><Run Text=" "/><Run Text="  协议段: "/><Run Text="{Binding SegmentCount, Mode=OneWay}"/></TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <Grid Grid.Column="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="EditorTitle" Foreground="#E6E6E6" FontSize="17" FontWeight="SemiBold" VerticalAlignment="Center"
                       Text="请选择输出事件"/>
            <TextBlock x:Name="EditorPlaceholder" Grid.Row="1"
                       Text="请从左侧选择或添加一个输出事件。"
                       Foreground="Gray" FontSize="14" Margin="0,12,0,0" HorizontalAlignment="Center"/>
            <ScrollViewer x:Name="EditorPanel" Grid.Row="1" Margin="0,8,0,0" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="绑定" Style="{StaticResource SectionSubtitle}"/>
                    <DockPanel Style="{StaticResource ConfigFieldRow}">
                        <TextBlock Text="通信设备" Style="{StaticResource ConfigFieldLabel}"/>
                        <ComboBox x:Name="DeviceCombo" SelectionChanged="OnDeviceComboChanged"
                                  Style="{StaticResource BindingSelectorCombo}"/>
                    </DockPanel>
                    <DockPanel Style="{StaticResource ConfigFieldRow}">
                        <TextBlock Text="数据块" Style="{StaticResource ConfigFieldLabel}"/>
                        <ComboBox x:Name="BlockCombo" SelectionChanged="OnBlockComboChanged"
                                  Style="{StaticResource BindingSelectorCombo}"/>
                    </DockPanel>

                    <Border Height="1" Background="#303030" Margin="0,14,0,12"/>

                    <TextBlock Text="变量" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="变量名" FontSize="13" Foreground="#AAAAAA" Margin="4,0,0,0"/>
                        <TextBlock Grid.Column="1" Text="类型" FontSize="13" Foreground="#AAAAAA" Margin="4,0,0,0"/>
                        <TextBlock Grid.Column="2" Text="字节序" FontSize="13" Foreground="#AAAAAA" Margin="4,0,0,0"/>
                    </Grid>
                    <ItemsControl x:Name="VariableListControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource ColorSurface}" BorderBrush="{DynamicResource ColorSurfaceBorder}" BorderThickness="0,0,0,1" Padding="2,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="14" Height="28" VerticalContentAlignment="Center" Margin="2,0"/>
                                        <ComboBox Grid.Column="1" ItemsSource="{Binding DataTypeOptions}"
                                                  SelectedItem="{Binding SelectedType}" Style="{StaticResource LightComboBox}" Margin="2,0"/>
                                        <ComboBox Grid.Column="2" ItemsSource="{Binding ByteOrderOptions}"
                                                  SelectedItem="{Binding SelectedByteOrder}" Style="{StaticResource LightComboBox}" Margin="2,0"/>
                                        <Button Grid.Column="3" Content="✕" Width="30" Height="30" FontSize="14"
                                                Click="OnDeleteVariableClick" Tag="{Binding}" Padding="0"
                                                Background="Transparent" BorderBrush="Transparent" Foreground="#CC4444"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Content="+ 添加变量" Click="OnAddVariableClick" Height="32" FontSize="13"
                            Background="#2A2A2A" BorderBrush="#444444" Foreground="#999999"
                            Margin="0,6,0,0" HorizontalAlignment="Left" Width="110"/>

                    <Border Height="1" Background="#303030" Margin="0,14,0,12"/>

                    <TextBlock Text="协议组装" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="头部HEX" Width="96" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBox x:Name="HeaderHexBox" MinWidth="240" HorizontalAlignment="Left" Height="28"
                                 TextChanged="OnHeaderChanged" VerticalContentAlignment="Center"/>
                    </DockPanel>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="序号" FontSize="13" Foreground="#AAAAAA"/>
                        <TextBlock Grid.Column="1" Text="段类型" FontSize="13" Foreground="#AAAAAA" Margin="4,0,0,0"/>
                        <TextBlock Grid.Column="2" Text="值/变量" FontSize="13" Foreground="#AAAAAA" Margin="4,0,0,0"/>
                        <TextBlock Grid.Column="3" Text="常量类型" FontSize="13" Foreground="#AAAAAA" Margin="4,0,0,0"/>
                        <TextBlock Grid.Column="4" Text="常量字节序" FontSize="13" Foreground="#AAAAAA" Margin="4,0,0,0"/>
                    </Grid>
                    <ItemsControl x:Name="SegmentListControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource ColorSurface}" BorderBrush="{DynamicResource ColorSurfaceBorder}" BorderThickness="0,0,0,1" Padding="2,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Index}" VerticalAlignment="Center" FontSize="13"
                                                   Foreground="#999999" HorizontalAlignment="Center"/>
                                        <ComboBox Grid.Column="1" ItemsSource="{Binding KindOptions}"
                                                  SelectedItem="{Binding SelectedKind}" Style="{StaticResource LightComboBox}" Margin="2,0"/>
                                        <Grid Grid.Column="2" Margin="2,0">
                                            <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                     FontSize="13" Height="28" VerticalContentAlignment="Center"
                                                     Visibility="{Binding IsConstant, Converter={StaticResource BoolToVis}}"/>
                                            <ComboBox ItemsSource="{Binding VariableNames}" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                      IsEditable="True" Style="{StaticResource LightComboBox}"
                                                      Visibility="{Binding IsVariable, Converter={StaticResource BoolToVis}}"/>
                                        </Grid>
                                        <ComboBox Grid.Column="3" ItemsSource="{Binding DataTypeOptions}"
                                                  SelectedItem="{Binding SelectedType}" Style="{StaticResource LightComboBox}" Margin="2,0"
                                                  Visibility="{Binding IsConstant, Converter={StaticResource BoolToVis}}"/>
                                        <ComboBox Grid.Column="4" ItemsSource="{Binding ByteOrderOptions}"
                                                  SelectedItem="{Binding SelectedByteOrder}" Style="{StaticResource LightComboBox}" Margin="2,0"
                                                  Visibility="{Binding IsConstant, Converter={StaticResource BoolToVis}}"/>
                                        <Button Grid.Column="5" Content="✕" Width="30" Height="30" FontSize="14"
                                                Click="OnDeleteSegmentClick" Tag="{Binding}" Padding="0"
                                                Background="Transparent" BorderBrush="Transparent" Foreground="#CC4444"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Content="+ 添加协议段" Click="OnAddSegmentClick" Height="32" FontSize="13"
                            Background="#2A2A2A" BorderBrush="#444444" Foreground="#999999"
                            Margin="0,6,0,0" HorizontalAlignment="Left" Width="120"/>

                    <Border Height="1" Background="#303030" Margin="0,14,0,12"/>

                    <TextBlock Text="CRC 尾部" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="启用CRC" Width="96" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <ToggleButton x:Name="CrcToggle" Style="{StaticResource SwitchButton}"
                                      Checked="OnCrcToggleChanged" Unchecked="OnCrcToggleChanged" HorizontalAlignment="Left"/>
                    </DockPanel>
                    <StackPanel x:Name="CrcPanel" Visibility="Collapsed" Margin="48,0,0,0">
                        <DockPanel Margin="0,0,0,6">
                            <TextBlock Text="校验方法" Width="96" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <ComboBox x:Name="CrcMethodCombo" MinWidth="180" SelectionChanged="OnCrcMethodChanged" HorizontalAlignment="Left"
                                      Style="{StaticResource LightComboBox}"/>
                        </DockPanel>
                        <DockPanel Margin="0,0,0,6">
                            <TextBlock Text="CRC字节序" Width="96" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <ComboBox x:Name="CrcByteOrderCombo" MinWidth="180" SelectionChanged="OnCrcByteOrderChanged" HorizontalAlignment="Left"
                                      Style="{StaticResource LightComboBox}"/>
                        </DockPanel>
                        <DockPanel>
                            <TextBlock Text="包含头部" Width="96" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <ToggleButton x:Name="CrcIncludeHeaderToggle" Style="{StaticResource SwitchButton}"
                                          Checked="OnCrcIncludeHeaderChanged" Unchecked="OnCrcIncludeHeaderChanged" HorizontalAlignment="Left"/>
                        </DockPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>