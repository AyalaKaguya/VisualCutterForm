<UserControl x:Class="VisualMaster.Communication.UI.OutputEventsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ColorRootBg}"
             Foreground="White"
             FontSize="15">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/CommunicationDarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                <Setter Property="Height" Value="34"/>
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="#1E1E1E">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <DockPanel Background="#202020">
            <DockPanel DockPanel.Dock="Top" Margin="8">
                <TextBlock Text="输出事件" FontWeight="SemiBold"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="+" Width="30" Click="OnAddClick"/>
                    <Button Content="-" Width="30" Click="OnRemoveClick"/>
                </StackPanel>
            </DockPanel>
            <ListBox x:Name="EventList" Margin="8" SelectionChanged="OnEventSelected"
                     PreviewMouseRightButtonDown="OnListRightButtonDown">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="4,6">
                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                            <TextBlock FontSize="10" Foreground="#999999" Margin="0,2,0,0" TextTrimming="CharacterEllipsis">
                                <Run Text="设备:"/><Run Text="{Binding DeviceId}"/>
                                <Run Text="  块:"/><Run Text="{Binding BlockId}"/>
                            </TextBlock>
                            <TextBlock FontSize="10" Foreground="#777777" Margin="0,1,0,0"
                                       Text="{Binding Segments.Count, StringFormat='输出段: {0} 组'}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <Grid Grid.Column="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="EditorTitle" Foreground="#E6E6E6" FontSize="17" FontWeight="SemiBold" VerticalAlignment="Center"
                       Text="请选择输出事件"/>
            <TextBlock x:Name="EditorPlaceholder" Grid.Row="1"
                       Text="请从左侧选择或添加一个输出事件。"
                       Foreground="Gray" FontSize="14" TextAlignment="Center" Margin="0,12,0,0"/>
            <Grid x:Name="EditorPanel" Grid.Row="1" Margin="0,8,0,0" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="34"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="96"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="96"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="设备ID"/>
                <TextBox x:Name="DeviceBox" Grid.Column="1" TextChanged="OnEditorChanged"/>
                <TextBlock Grid.Column="2" Text="块ID" Margin="16,0,0,0"/>
                <TextBox x:Name="BlockBox" Grid.Column="3" TextChanged="OnEditorChanged"/>

                <GroupBox Grid.Row="1" Grid.ColumnSpan="4" Header="变量" Foreground="White" Margin="0,10,0,6">
                    <DataGrid x:Name="VariableGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="True"
                              ItemsSource="{Binding Variables}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="变量名" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="类型" Binding="{Binding DataType}" Width="120"/>
                            <DataGridTextColumn Header="顺序" Binding="{Binding ByteOrder}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>

                <GroupBox Grid.Row="3" Grid.ColumnSpan="4" Header="输出格式" Foreground="White" Margin="0,6,0,0">
                    <DataGrid x:Name="SegmentGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="True"
                              ItemsSource="{Binding Segments}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="类型" Binding="{Binding Kind}" Width="110"/>
                            <DataGridTextColumn Header="值/变量名" Binding="{Binding Value}" Width="*"/>
                            <DataGridTextColumn Header="数据类型" Binding="{Binding DataType}" Width="120"/>
                            <DataGridTextColumn Header="顺序" Binding="{Binding ByteOrder}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
