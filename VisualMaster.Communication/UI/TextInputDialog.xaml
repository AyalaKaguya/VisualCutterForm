<Window x:Class="VisualMaster.Communication.UI.TextInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="360"
        Height="160"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="34"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="PromptText" Foreground="#CCCCCC" Margin="0,0,0,8"/>
        <TextBox x:Name="ValueBox" Grid.Row="1" Background="#2B2B2B" Foreground="White" BorderBrush="#555555" Padding="5,3"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="确定" Width="72" Margin="4" Click="OnOkClick"/>
            <Button Content="取消" Width="72" Margin="4" Click="OnCancelClick"/>
        </StackPanel>
    </Grid>
</Window>
