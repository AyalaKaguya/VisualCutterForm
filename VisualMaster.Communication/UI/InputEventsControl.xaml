<UserControl x:Class="VisualMaster.Communication.UI.InputEventsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E"
             Foreground="White">
    <UserControl.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="3"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2B2B2B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Padding" Value="5,3"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#151515"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444444"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="RowBackground" Value="#242424"/>
            <Setter Property="AlternatingRowBackground" Value="#202020"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#444444"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#303030"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="#1E1E1E">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <DockPanel Background="#202020">
            <DockPanel DockPanel.Dock="Top" Margin="8">
                <TextBlock Text="输入事件" FontWeight="SemiBold"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="+" Width="30" Click="OnAddClick"/>
                    <Button Content="-" Width="30" Click="OnRemoveClick"/>
                </StackPanel>
            </DockPanel>
            <ListBox x:Name="EventList"
                     Margin="8"
                     DisplayMemberPath="Name"
                     SelectionChanged="OnEventSelected"/>
        </DockPanel>

        <Grid Grid.Column="1" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="96"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="96"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="34"/>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="名称"/>
            <TextBox x:Name="NameBox" Grid.Column="1" TextChanged="OnEditorChanged"/>
            <TextBlock Grid.Column="2" Text="ASCII" Margin="16,0,0,0"/>
            <CheckBox x:Name="AsciiBox" Grid.Column="3" Checked="OnEditorChanged" Unchecked="OnEditorChanged"/>

            <TextBlock Grid.Row="1" Text="设备ID"/>
            <TextBox x:Name="DeviceBox" Grid.Row="1" Grid.Column="1" TextChanged="OnEditorChanged"/>
            <TextBlock Grid.Row="1" Grid.Column="2" Text="块ID" Margin="16,0,0,0"/>
            <TextBox x:Name="BlockBox" Grid.Row="1" Grid.Column="3" TextChanged="OnEditorChanged"/>

            <TextBlock Grid.Row="2" Text="最小长度"/>
            <TextBox x:Name="MinLengthBox" Grid.Row="2" Grid.Column="1" TextChanged="OnEditorChanged"/>

            <GroupBox Grid.Row="3" Grid.ColumnSpan="4" Header="匹配规则" Foreground="White" Margin="0,10,0,0">
                <DataGrid x:Name="RuleGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="True"
                          ItemsSource="{Binding Rules}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="序号" Binding="{Binding Order}" Width="60"/>
                        <DataGridTextColumn Header="触发器名称" Binding="{Binding TriggerName}" Width="140"/>
                        <DataGridTextColumn Header="起始" Binding="{Binding StartIndex}" Width="70"/>
                        <DataGridTextColumn Header="长度" Binding="{Binding Length}" Width="70"/>
                        <DataGridTextColumn Header="类型" Binding="{Binding DataType}" Width="100"/>
                        <DataGridTextColumn Header="顺序" Binding="{Binding ByteOrder}" Width="100"/>
                        <DataGridTextColumn Header="匹配" Binding="{Binding Operator}" Width="110"/>
                        <DataGridTextColumn Header="匹配值" Binding="{Binding MatchValue}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>
    </Grid>
</UserControl>
