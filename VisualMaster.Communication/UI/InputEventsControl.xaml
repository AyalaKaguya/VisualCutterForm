<UserControl x:Class="VisualMaster.Communication.UI.InputEventsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ColorRootBg}"
             Foreground="White"
             FontSize="15">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/CommunicationDarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                <Setter Property="Height" Value="34"/>
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Background="{DynamicResource ColorRootBg}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <DockPanel Background="#202020">
            <DockPanel DockPanel.Dock="Top" Margin="8">
                <TextBlock Text="输入事件" FontWeight="SemiBold"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="+" Width="30" Click="OnAddClick"/>
                    <Button Content="-" Width="30" Click="OnRemoveClick"/>
                </StackPanel>
            </DockPanel>
            <ListBox x:Name="EventList"
                     Margin="8"
                     SelectionChanged="OnEventSelected"
                     PreviewMouseRightButtonDown="OnListRightButtonDown">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="4,6">
                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                            <TextBlock FontSize="10" Foreground="#999999" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"
                                       Text="{Binding BindingInfo}"/>
                            <TextBlock FontSize="10" Foreground="#777777" Margin="0,1,0,0"
                                       Text="{Binding Rules.Count, StringFormat='规则: {0} 条'}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <Grid Grid.Column="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="EditorTitle" Foreground="#E6E6E6" FontSize="17" FontWeight="SemiBold" VerticalAlignment="Center"
                       Text="请选择输入事件"/>
            <TextBlock x:Name="EditorPlaceholder" Grid.Row="1"
                       Text="请从左侧选择或添加一个输入事件。"
                       Foreground="Gray" FontSize="14" Margin="0,12,0,0"/>
            <Grid x:Name="EditorPanel" Grid.Row="1" Margin="0,8,0,0" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <GroupBox Grid.Row="0" Header="绑定" Foreground="White" Margin="0,0,0,10">
                    <StackPanel Margin="6">
                        <DockPanel Margin="0,0,0,10">
                            <TextBlock Text="通信设备" Width="96" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <ComboBox x:Name="DeviceCombo" SelectionChanged="OnDeviceComboChanged"/>
                        </DockPanel>
                        <DockPanel>
                            <TextBlock Text="数据块" Width="96" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <ComboBox x:Name="BlockCombo" SelectionChanged="OnBlockComboChanged"/>
                        </DockPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox Grid.Row="1" Header="基本配置" Foreground="White" Margin="0,0,0,10">
                    <DockPanel Margin="6">
                        <TextBlock Text="最小匹配长度" Width="110" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBox x:Name="MinLengthBox" TextChanged="OnMinLengthChanged" Width="80" HorizontalAlignment="Left"/>
                    </DockPanel>
                </GroupBox>

                <GroupBox Grid.Row="2" Header="规则配置" Foreground="White">
                    <DataGrid x:Name="RuleGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="True"
                              ItemsSource="{Binding Rules}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="序号" Binding="{Binding Order}" Width="60"/>
                            <DataGridTextColumn Header="触发器名称" Binding="{Binding TriggerName}" Width="140"/>
                            <DataGridTextColumn Header="起始" Binding="{Binding StartIndex}" Width="70"/>
                            <DataGridTextColumn Header="长度" Binding="{Binding Length}" Width="70"/>
                            <DataGridTextColumn Header="类型" Binding="{Binding DataType}" Width="100"/>
                            <DataGridTextColumn Header="顺序" Binding="{Binding ByteOrder}" Width="100"/>
                            <DataGridTextColumn Header="匹配" Binding="{Binding Operator}" Width="110"/>
                            <DataGridTextColumn Header="匹配值" Binding="{Binding MatchValue}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
