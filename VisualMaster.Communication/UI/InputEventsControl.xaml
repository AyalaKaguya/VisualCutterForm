<UserControl x:Class="VisualMaster.Communication.UI.InputEventsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:VisualMaster.Communication.UI.Converters"
             xmlns:vm="clr-namespace:VisualMaster.Communication.UI.ViewModels"
             Background="{DynamicResource ColorRootBg}"
             Foreground="White"
             FontSize="15">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/CommunicationDarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                <Setter Property="Height" Value="34"/>
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <Style x:Key="LightComboBox" TargetType="ComboBox">
                <Style.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="Black"/>
                    </Style>
                </Style.Resources>
                <Setter Property="Background" Value="White"/>
                <Setter Property="Foreground" Value="Black"/>
                <Setter Property="TextElement.Foreground" Value="Black"/>
                <Setter Property="Height" Value="28"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="ItemContainerStyle">
                    <Setter.Value>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="TextElement.Foreground" Value="Black"/>
                        </Style>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="DeviceToggle" TargetType="ToggleButton">
                <Setter Property="Background" Value="#4A4A4A"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="Track" Width="42" Height="24" Background="{TemplateBinding Background}" CornerRadius="12">
                                <Ellipse x:Name="Thumb" Width="20" Height="20" Fill="White" HorizontalAlignment="Left" Margin="2"/>
                            </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#2EAA5F"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Background="{DynamicResource ColorRootBg}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <DockPanel Background="#202020">
            <DockPanel DockPanel.Dock="Top" Margin="8">
                <TextBlock Text="输入事件" FontWeight="SemiBold"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="+" Width="30" Click="OnAddClick"/>
                    <Button Content="-" Width="30" Click="OnRemoveClick"/>
                </StackPanel>
            </DockPanel>
            <ListBox x:Name="EventList"
                     Margin="8"
                     SelectionChanged="OnEventSelected"
                     PreviewMouseRightButtonDown="OnListRightButtonDown">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="4,6">
                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                            <TextBlock FontSize="10" Foreground="#999999" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"
                                       Text="{Binding BindingInfo}"/>
                            <TextBlock FontSize="10" Foreground="#777777" Margin="0,1,0,0"
                                       Text="{Binding Rules.Count, StringFormat='规则: {0} 条'}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <Grid Grid.Column="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="EditorTitle" Foreground="#E6E6E6" FontSize="17" FontWeight="SemiBold" VerticalAlignment="Center"
                       Text="请选择输入事件"/>
            <TextBlock x:Name="EditorPlaceholder" Grid.Row="1"
                       Text="请从左侧选择或添加一个输入事件。"
                       Foreground="Gray" FontSize="14" Margin="0,12,0,0" HorizontalAlignment="Center"/>
            <StackPanel x:Name="EditorPanel" Grid.Row="1" Margin="0,8,0,0" Visibility="Collapsed">
                <TextBlock Text="绑定" FontWeight="SemiBold" Margin="0,10,0,6"/>
                <DockPanel Margin="0,0,0,6">
                    <TextBlock Text="通信设备" Width="96" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <ComboBox x:Name="DeviceCombo" MinWidth="240" SelectionChanged="OnDeviceComboChanged" HorizontalAlignment="Left"/>
                </DockPanel>
                <DockPanel Margin="0,0,0,6">
                    <TextBlock Text="数据块" Width="96" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <ComboBox x:Name="BlockCombo" MinWidth="240" SelectionChanged="OnBlockComboChanged" HorizontalAlignment="Left"/>
                </DockPanel>

                <Border Height="1" Background="#303030" Margin="0,14,0,12"/>

                <TextBlock Text="基本配置" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="字节长度比较" Width="110" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <ToggleButton x:Name="LengthCheckToggle" Style="{StaticResource DeviceToggle}"
                                  Checked="OnLengthCheckChanged" Unchecked="OnLengthCheckChanged" HorizontalAlignment="Left"/>
                </DockPanel>

                <StackPanel x:Name="LengthCheckPanel" Visibility="Collapsed" Margin="48,0,0,0">
                    <DockPanel Margin="0,0,0,6" HorizontalAlignment="Left">
                        <TextBlock Text="最少字符数" Width="110" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <ToggleButton x:Name="MinLengthToggle" Style="{StaticResource DeviceToggle}"
                                      Checked="OnMinLengthToggleChanged" Unchecked="OnMinLengthToggleChanged"/>
                        <DockPanel Width="90" Margin="12,0,0,0">
                            <StackPanel DockPanel.Dock="Right" Width="20">
                                <RepeatButton Content="▲" FontSize="8" Padding="0" Height="15"
                                              Click="OnMinLengthUp"/>
                                <RepeatButton Content="▼" FontSize="8" Padding="0" Height="15"
                                              Click="OnMinLengthDown"/>
                            </StackPanel>
                            <TextBox x:Name="MinLengthBox" TextChanged="OnMinLengthChanged"
                                     PreviewTextInput="OnNumericPreviewTextInput" VerticalContentAlignment="Center"/>
                        </DockPanel>
                    </DockPanel>
                    <DockPanel Margin="0,0,0,6">
                        <TextBlock Text="等于字符数" Width="110" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <ToggleButton x:Name="ExactLengthToggle" Style="{StaticResource DeviceToggle}"
                                      Checked="OnExactLengthToggleChanged" Unchecked="OnExactLengthToggleChanged"/>
                        <DockPanel Width="90" Margin="12,0,0,0" HorizontalAlignment="Left">
                            <StackPanel DockPanel.Dock="Right" Width="20">
                                <RepeatButton Content="▲" FontSize="8" Padding="0" Height="15"
                                              Click="OnExactLengthUp"/>
                                <RepeatButton Content="▼" FontSize="8" Padding="0" Height="15"
                                              Click="OnExactLengthDown"/>
                            </StackPanel>
                            <TextBox x:Name="ExactLengthBox" TextChanged="OnExactLengthChanged"
                                     PreviewTextInput="OnNumericPreviewTextInput" VerticalContentAlignment="Center"/>
                        </DockPanel>
                    </DockPanel>
                    <DockPanel>
                        <TextBlock Text="按ASCII字符计算" Width="130" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <ToggleButton x:Name="AsciiToggle" Style="{StaticResource DeviceToggle}"
                                      Checked="OnAsciiToggleChanged" Unchecked="OnAsciiToggleChanged" HorizontalAlignment="Left"/>
                    </DockPanel>
                </StackPanel>

                <Border Height="1" Background="#303030" Margin="0,14,0,12"/>

                <TextBlock Text="规则配置" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="36"/>
                        <ColumnDefinition Width="135"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="序号" FontSize="13" Foreground="#AAAAAA"/>
                    <TextBlock Grid.Column="1" Text="名称" FontSize="13" Foreground="#AAAAAA" Margin="4,0,0,0"/>
                    <TextBlock Grid.Column="2" Text="起止位置" FontSize="13" Foreground="#AAAAAA" Margin="4,0,0,0"/>
                    <TextBlock Grid.Column="3" Text="类型" FontSize="13" Foreground="#AAAAAA" Margin="4,0,0,0"/>
                    <TextBlock Grid.Column="4" Text="字节序" FontSize="13" Foreground="#AAAAAA" Margin="4,0,0,0"/>
                    <TextBlock Grid.Column="5" Text="规则" FontSize="13" Foreground="#AAAAAA" Margin="4,0,0,0"/>
                    <TextBlock Grid.Column="6" Text="参数" FontSize="13" Foreground="#AAAAAA" Margin="4,0,0,0"/>
                </Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="320">
                    <ItemsControl x:Name="RuleListControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#242424" BorderBrush="#3A3A3A" BorderThickness="0,0,0,1" Padding="2,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36"/>
                                            <ColumnDefinition Width="135"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Index}" VerticalAlignment="Center" FontSize="13" 
                                                   Foreground="#999999" HorizontalAlignment="Center"/>
                                        <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                                                 FontSize="14" Height="28" VerticalContentAlignment="Center" Margin="2,0"/>
                                        <Grid Grid.Column="2" Margin="2,0" VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="14"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="14"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Text="{Binding StartOffset, UpdateSourceTrigger=PropertyChanged}" 
                                                     FontSize="13" Height="28" VerticalContentAlignment="Center"
                                                     PreviewTextInput="OnRuleNumericPreviewTextInput"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <RepeatButton Content="▴" FontSize="6" Height="14" Padding="0" Margin="0"
                                                              Click="OnRuleStartUp" Tag="{Binding}"/>
                                                <RepeatButton Content="▾" FontSize="6" Height="14" Padding="0" Margin="0"
                                                              Click="OnRuleStartDown" Tag="{Binding}"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="-" FontSize="13" VerticalAlignment="Center"
                                                       HorizontalAlignment="Center" Foreground="#999999"/>
                                            <TextBox Grid.Column="3" Text="{Binding EndOffset, UpdateSourceTrigger=PropertyChanged}" 
                                                     FontSize="13" Height="28" VerticalContentAlignment="Center"
                                                     PreviewTextInput="OnRuleNumericPreviewTextInput"/>
                                            <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                                <RepeatButton Content="▴" FontSize="6" Height="14" Padding="0" Margin="0"
                                                              Click="OnRuleEndUp" Tag="{Binding}"/>
                                                <RepeatButton Content="▾" FontSize="6" Height="14" Padding="0" Margin="0"
                                                              Click="OnRuleEndDown" Tag="{Binding}"/>
                                            </StackPanel>
                                        </Grid>
                                        <ComboBox Grid.Column="3" ItemsSource="{Binding Source={x:Static vm:RuleItemViewModel.DataTypeOptions}}"
                                                  SelectedItem="{Binding SelectedType}" Style="{StaticResource LightComboBox}" Margin="2,0"/>
                                        <ComboBox Grid.Column="4" ItemsSource="{Binding Source={x:Static vm:RuleItemViewModel.ByteOrderOptions}}"
                                                  SelectedItem="{Binding SelectedByteOrder}" Style="{StaticResource LightComboBox}" Margin="2,0"/>
                                        <ComboBox Grid.Column="5" ItemsSource="{Binding Source={x:Static vm:RuleItemViewModel.OperatorOptions}}"
                                                  SelectedItem="{Binding SelectedOperator}" Style="{StaticResource LightComboBox}" Margin="2,0"/>
                                        <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                                            <StackPanel Orientation="Horizontal" Visibility="{Binding NeedsTwoParams, Converter={StaticResource BoolToVis}}">
                                                <TextBox Text="{Binding BeforeValue, UpdateSourceTrigger=PropertyChanged}" Width="56" Height="28"
                                                         FontSize="13" VerticalContentAlignment="Center" Margin="0,0,4,0"/>
                                                <TextBlock Text="→" FontSize="13" VerticalAlignment="Center" Foreground="#999999"
                                                           Margin="0,0,4,0"/>
                                                <TextBox Text="{Binding AfterValue, UpdateSourceTrigger=PropertyChanged}" Width="56" Height="28"
                                                         FontSize="13" VerticalContentAlignment="Center"/>
                                            </StackPanel>
                                            <TextBox Text="{Binding MatchValue, UpdateSourceTrigger=PropertyChanged}" Width="80" Height="28"
                                                     FontSize="13" VerticalContentAlignment="Center"
                                                     Visibility="{Binding NeedsOneParam, Converter={StaticResource BoolToVis}}"/>
                                        </StackPanel>
                                        <Button Grid.Column="7" Content="✕" Width="30" Height="30" FontSize="14"
                                                Click="OnDeleteRuleClick" Tag="{Binding}" Padding="0"
                                                Background="Transparent" BorderBrush="Transparent" Foreground="#CC4444"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <Button Content="+ 添加规则" Click="OnAddRuleClick" Height="32" FontSize="13"
                        Background="#2A2A2A" BorderBrush="#444444" Foreground="#999999"
                        Margin="0,6,0,0" HorizontalAlignment="Left" Width="110"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
