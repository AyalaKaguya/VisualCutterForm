<UserControl x:Class="VisualMaster.Communication.UI.TcpDriverConfigControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ColorRootBg}"
             Foreground="White"
             FontSize="15">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/CommunicationDarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12">
            <TextBlock Text="TCP 网络驱动" Style="{StaticResource EditorPageTitle}"/>
            <TextBlock Text="连接配置" Style="{StaticResource SectionSubtitle}" Margin="0,0,0,8"/>

            <DockPanel Style="{StaticResource ConfigFieldRow}">
                <TextBlock Text="IP 地址" Style="{StaticResource ConfigFieldLabel}"/>
                <TextBox x:Name="IpBox" Style="{StaticResource FormValueTextBox}"
                         Text="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}"/>
            </DockPanel>

            <DockPanel Style="{StaticResource ConfigFieldRow}">
                <TextBlock Text="端口" Style="{StaticResource ConfigFieldLabel}"/>
                <TextBox x:Name="PortBox" Style="{StaticResource FormValueTextBox}"
                         Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"/>
            </DockPanel>

            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="数据块" Style="{StaticResource SectionSubtitle}" Margin="0,0,0,8"/>
                    <DockPanel Style="{StaticResource ConfigFieldRow}" Margin="0">
                        <TextBlock Text="绑定块名称" Style="{StaticResource ConfigFieldLabel}"/>
                        <TextBox x:Name="BlockNameBox" Style="{StaticResource FormValueTextBox}"
                                 Text="{Binding BlockName, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Content="实时" MinWidth="78" Style="{StaticResource ActionButtonSmall}" Margin="12,0,0,0" Click="OnRealtimeClick"/>
                    </DockPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
