<UserControl x:Class="VisualMaster.Communication.UI.CommunicationBlockListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Foreground="White">
    <UserControl.Resources>
        <DataTemplate x:Key="BlockItemTemplate">
            <Border Background="#242424" BorderBrush="#3A3A3A" BorderThickness="1" Padding="10" Margin="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                        <TextBlock Text="{Binding Address}" Foreground="#9A9A9A" FontSize="11" Margin="0,3,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Text="{Binding DataType}" Foreground="#CCCCCC" FontSize="11"/>
                            <TextBlock Text="  |  " Foreground="#666666" FontSize="11"/>
                            <TextBlock Text="{Binding PollingEnabled, StringFormat=轮询: {0}}" Foreground="#CCCCCC" FontSize="11"/>
                            <TextBlock Text="  |  " Foreground="#666666" FontSize="11"/>
                            <TextBlock Text="{Binding PollingIntervalMs, StringFormat=周期: {0}ms}" Foreground="#CCCCCC" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444444"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="3"/>
        </Style>
    </UserControl.Resources>
    <DockPanel Background="#1E1E1E">
        <ToolBar DockPanel.Dock="Top" Background="#252525">
            <Button Content="新增块" Foreground="White"  Click="OnAddClick"/>
            <Button Content="删除块" Foreground="White" Click="OnRemoveClick"/>
            <Button Content="监视" Foreground="White" Click="OnMonitorClick"/>
        </ToolBar>
        <ListBox x:Name="Grid"
                 ItemTemplate="{StaticResource BlockItemTemplate}"/>
    </DockPanel>
</UserControl>
