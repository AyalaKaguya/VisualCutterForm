<UserControl x:Class="VisualMaster.Communication.UI.CommunicationBlockListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Foreground="White">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/CommunicationDarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <DockPanel Background="{DynamicResource ColorRootBg}">
        <ToolBar DockPanel.Dock="Top" Style="{StaticResource CommunicationToolBar}">
            <Button Content="新增块" Foreground="White"  Click="OnAddClick"/>
            <Button Content="删除块" Foreground="White" Click="OnRemoveClick"/>
            <Button Content="监视" Foreground="White" Click="OnMonitorClick"/>
        </ToolBar>
        <ListBox x:Name="Grid"
                 ItemTemplate="{StaticResource BlockItemTemplate}"/>
    </DockPanel>
</UserControl>
