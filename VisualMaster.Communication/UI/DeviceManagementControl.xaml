<UserControl x:Class="VisualMaster.Communication.UI.DeviceManagementControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="clr-namespace:VisualMaster.Communication.UI"
             xmlns:vm="clr-namespace:VisualMaster.Communication.UI.ViewModels"
             Background="{DynamicResource ColorRootBg}"
             Foreground="White">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/CommunicationDarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="DeviceToggle" TargetType="ToggleButton">
                <Setter Property="Background" Value="#4A4A4A"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="Track" Width="42" Height="24" Background="{TemplateBinding Background}" CornerRadius="12">
                                <Ellipse x:Name="Thumb" Width="20" Height="20" Fill="White" HorizontalAlignment="Left" Margin="2"/>
                            </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#2EAA5F"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <DataTemplate x:Key="DeviceItemTemplate">
            <Grid Margin="6,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Margin="0,0,8,0">
                    <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding DriverName}" Foreground="#B0B0B0" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>
                <ToggleButton Grid.Column="1"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"
                              Style="{StaticResource DeviceToggle}"
                              IsChecked="{Binding IsEnabled}"
                              Tag="{Binding DeviceId}"
                              Checked="OnDeviceEnabledToggled"
                              Unchecked="OnDeviceEnabledToggled"/>
            </Grid>
        </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0" Background="#202020">
            <DockPanel DockPanel.Dock="Top" Margin="8">
                <TextBlock Text="设备列表" FontWeight="SemiBold"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="+" Width="30" Click="OnAddDeviceClick"/>
                    <Button Content="-" Width="30" Click="OnRemoveDeviceClick"/>
                </StackPanel>
            </DockPanel>
            <ListBox x:Name="DeviceList"
                     Margin="8"
                     ItemsSource="{Binding Devices}"
                     ItemTemplate="{StaticResource DeviceItemTemplate}"
                     SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                     PreviewMouseRightButtonDown="OnDeviceListRightButtonDown"/>
        </DockPanel>

        <Grid Grid.Column="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="0"/>
            </Grid.RowDefinitions>
            <DockPanel x:Name="DeviceCommandBar">
                <TextBlock x:Name="DeviceTitleText"
                           Text="{Binding SelectedDevice.DisplayName, FallbackValue=请选择或添加一个通信设备}"
                           Foreground="#E6E6E6" FontSize="17" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </DockPanel>
            <ContentControl x:Name="DriverConfigHost" Grid.Row="1" Margin="0,8,0,8"/>
            <ui:CommunicationBlockListControl x:Name="BlockList" Grid.Row="2"/>
        </Grid>
    </Grid>
</UserControl>
