<UserControl x:Class="VisualMaster.Communication.UI.DeviceManagementControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="clr-namespace:VisualMaster.Communication.UI"
             Background="#1E1E1E"
             Foreground="White">
    <UserControl.Resources>
        <Style x:Key="DeviceToggle" TargetType="ToggleButton">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="#4A4A4A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Track" Background="{TemplateBinding Background}" CornerRadius="13">
                            <Ellipse x:Name="Thumb" Width="22" Height="22" Fill="White" HorizontalAlignment="Left" Margin="2"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#2EAA5F"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <DataTemplate x:Key="DeviceItemTemplate">
            <Grid Margin="8,9">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding DisplayName}" FontSize="16" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding DriverName}" Foreground="#B0B0B0" FontSize="13" Margin="0,3,0,0"/>
                    <TextBlock Text="{Binding InterfaceName}" Foreground="#8A8A8A" FontSize="13" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <ToggleButton Grid.Column="1"
                              Style="{StaticResource DeviceToggle}"
                              IsChecked="{Binding IsEnabled}"
                              Tag="{Binding DeviceId}"
                              Checked="OnDeviceEnabledToggled"
                              Unchecked="OnDeviceEnabledToggled"/>
            </Grid>
        </DataTemplate>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="3"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2B2B2B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Padding" Value="5,3"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#151515"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444444"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="RowBackground" Value="#242424"/>
            <Setter Property="AlternatingRowBackground" Value="#202020"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#444444"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#303030"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0" Background="#202020">
            <DockPanel DockPanel.Dock="Top" Margin="8">
                <TextBlock Text="设备列表" FontWeight="SemiBold"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="+" Width="30" Click="OnAddDeviceClick"/>
                    <Button Content="-" Width="30" Click="OnRemoveDeviceClick"/>
                </StackPanel>
            </DockPanel>
            <ListBox x:Name="DeviceList"
                     Margin="8"
                     ItemTemplate="{StaticResource DeviceItemTemplate}"
                     SelectionChanged="OnDeviceSelected"
                     PreviewMouseRightButtonDown="OnDeviceListRightButtonDown"/>
        </DockPanel>

        <Grid Grid.Column="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="0"/>
            </Grid.RowDefinitions>
            <DockPanel x:Name="DeviceCommandBar">
                <TextBlock x:Name="DeviceTitleText" Foreground="#E6E6E6" FontSize="17" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </DockPanel>
            <ContentControl x:Name="DriverConfigHost" Grid.Row="1" Margin="0,8,0,8"/>
            <ui:CommunicationBlockListControl x:Name="BlockList" Grid.Row="2"/>
        </Grid>
    </Grid>
</UserControl>
