<UserControl x:Class="VisualMaster.Communication.UI.HeartbeatControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Foreground="White">
    <UserControl.Resources>
        <ResourceDictionary Source="../Themes/CommunicationDarkTheme.xaml"/>
    </UserControl.Resources>
    <Grid Background="{StaticResource ColorRootBg}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <DockPanel Background="#202020">
            <DockPanel DockPanel.Dock="Top" Margin="8">
                <TextBlock Text="心跳" FontWeight="SemiBold"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="+" Width="30" Click="OnAddClick"/>
                    <Button Content="-" Width="30" Click="OnRemoveClick"/>
                </StackPanel>
            </DockPanel>
            <ListBox x:Name="HeartbeatList" Margin="8" DisplayMemberPath="Name" SelectionChanged="OnHeartbeatSelected"/>
        </DockPanel>

        <Grid Grid.Column="1" Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="34"/>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="启用"/>
            <CheckBox x:Name="EnabledBox" Grid.Column="1" Checked="OnEditorChanged" Unchecked="OnEditorChanged"/>
            <TextBlock Grid.Row="1" Text="名称"/>
            <TextBox x:Name="NameBox" Grid.Row="1" Grid.Column="1" TextChanged="OnEditorChanged"/>
            <TextBlock Grid.Row="2" Text="输入事件ID"/>
            <TextBox x:Name="InputEventBox" Grid.Row="2" Grid.Column="1" TextChanged="OnEditorChanged"/>
            <TextBlock Grid.Row="3" Text="输出事件ID" VerticalAlignment="Top" Margin="0,8,0,0"/>
            <TextBox x:Name="OutputEventBox" Grid.Row="3" Grid.Column="1" Height="28" VerticalAlignment="Top" Margin="0,4,0,0" TextChanged="OnEditorChanged"/>
        </Grid>
    </Grid>
</UserControl>
