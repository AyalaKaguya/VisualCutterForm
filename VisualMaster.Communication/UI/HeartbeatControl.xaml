<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="VisualMaster.Communication.UI.HeartbeatControl"
             Foreground="White"
             FontSize="15">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/CommunicationDarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Background="{DynamicResource ColorRootBg}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <DockPanel Background="#202020">
            <DockPanel DockPanel.Dock="Top" Margin="8">
                <TextBlock Text="心跳" FontWeight="SemiBold"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="+" Width="30" Click="OnAddClick"/>
                    <Button Content="-" Width="30" Click="OnRemoveClick"/>
                </StackPanel>
            </DockPanel>
            <ListBox x:Name="HeartbeatList" Margin="8" SelectionChanged="OnHeartbeatSelected"
                     PreviewMouseRightButtonDown="OnListRightButtonDown" d:ItemsSource="{d:SampleData ItemCount=5}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="4,6">
                            <DockPanel>
                                <ToggleButton DockPanel.Dock="Right"
                                              Style="{StaticResource DeviceToggle}"
                                              IsChecked="{Binding IsEnabled}"
                                              Click="OnListToggleClick"
                                              Tag="{Binding}"
                                              Margin="8,0,0,0"/>
                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                            </DockPanel>
                            <TextBlock FontSize="10" Foreground="#999999" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"
                                       Text="{Binding BindingInfo}"/>
                            <TextBlock FontSize="10" Foreground="#737373" Margin="0,1,0,0" TextTrimming="CharacterEllipsis"
                                       Text="{Binding OutputInfo}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <Grid Grid.Column="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="EditorTitle" Foreground="#E6E6E6" FontSize="17" FontWeight="SemiBold" VerticalAlignment="Center"
                       Text="请选择心跳"/>
            <TextBlock x:Name="EditorPlaceholder" Grid.Row="1"
                       Text="请从左侧选择或添加一个心跳。"
                       Foreground="Gray" FontSize="14" TextAlignment="Center" Margin="0,12,0,0"/>
            <StackPanel x:Name="EditorPanel" Grid.Row="1" Margin="0,8,0,0" Visibility="Collapsed">
                <TextBlock Text="绑定" FontWeight="SemiBold" Margin="0,10,0,6"/>
                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="输入触发器" Width="110" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <ComboBox x:Name="InputRuleCombo" MinWidth="280" SelectionChanged="OnInputRuleChanged"
                              HorizontalAlignment="Left" Style="{StaticResource LightComboBox}"/>
                </DockPanel>
                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="输出事件" Width="110" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <ComboBox x:Name="OutputEventCombo" MinWidth="280" SelectionChanged="OnOutputEventChanged"
                              HorizontalAlignment="Left" Style="{StaticResource LightComboBox}"/>
                </DockPanel>

                <Border Height="1" Background="#303030" Margin="0,14,0,12"/>

                <TextBlock Text="输出变量" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="240"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="变量名" FontSize="13" Foreground="#AAAAAA" Margin="4,0,0,0"/>
                    <TextBlock Grid.Column="1" Text="类型" FontSize="13" Foreground="#AAAAAA" Margin="4,0,0,0"/>
                    <TextBlock Grid.Column="2" Text="值" FontSize="13" Foreground="#AAAAAA" Margin="4,0,0,0"/>
                </Grid>
                <ItemsControl x:Name="VariableListControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#242424" BorderBrush="#3A3A3A" BorderThickness="0,0,0,1" Padding="2,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="240"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Name}" FontSize="13" VerticalAlignment="Center"
                                               Foreground="#E6E6E6" Margin="4,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding TypeDisplay}" FontSize="13" VerticalAlignment="Center"
                                               Foreground="#AAAAAA" Margin="4,0"/>
                                    <TextBox Grid.Column="2" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="13" Height="28" VerticalContentAlignment="Center" Margin="2,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>