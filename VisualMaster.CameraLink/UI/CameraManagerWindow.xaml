<Window x:Class="VisualMaster.CameraLink.UI.CameraManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:VisualMaster.CameraLink.UI"
        Title="相机管理" Height="640" Width="960"
        Background="{DynamicResource CameraColorRootBg}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <ResourceDictionary Source="../Themes/CameraDarkTheme.xaml"/>
    </Window.Resources>

    <Grid>
        <ui:CameraManagerPanel x:Name="Panel"/>
    </Grid>
</Window>
