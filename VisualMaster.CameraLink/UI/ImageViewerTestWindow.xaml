<Window x:Class="VisualMaster.CameraLink.UI.ImageViewerTestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:VisualMaster.CameraLink.UI"
        Title="图像预览测试"
        Width="980"
        Height="700"
        MinWidth="720"
        MinHeight="480"
        Background="{DynamicResource CameraColorViewerBg}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <ResourceDictionary Source="../Themes/CameraDarkTheme.xaml"/>
    </Window.Resources>
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{DynamicResource CameraColorSidePanel}" BorderBrush="#444444" BorderThickness="0,0,0,1" Padding="8,5">
            <StackPanel Orientation="Horizontal">
                <Button Content="打开本地文件" MinWidth="110" Padding="10,5" Click="OnOpenFileClick" Style="{StaticResource DarkButton}"/>
                <TextBlock x:Name="PathText" Foreground="{DynamicResource CameraColorTextDim}" VerticalAlignment="Center" Margin="12,0,0,0" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </Border>
        <ui:CameraImageViewer x:Name="Viewer"/>
    </DockPanel>
</Window>
