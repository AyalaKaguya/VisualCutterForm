<Window x:Class="VisualMaster.CameraLink.UI.CameraPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:VisualMaster.CameraLink.UI"
        Title="相机预览"
        Width="980"
        Height="700"
        MinWidth="720"
        MinHeight="480"
        Background="{DynamicResource CameraColorViewerBg}"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/CameraDarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{DynamicResource CameraColorSidePanel}" BorderBrush="#444444" BorderThickness="0,0,0,1" Padding="8,5">
            <StackPanel Orientation="Horizontal">
                <Button Content="&#xE8B7;" Style="{StaticResource PreviewIconButton}" Click="OnOpenGrabbingClick" ToolTip="打开相机取像"/>
                <Button Content="&#xE722;" Style="{StaticResource PreviewIconButton}" Click="OnSingleFrameClick" ToolTip="单帧取像"/>
                <Button Content="&#xE768;" Style="{StaticResource PreviewIconButton}" Click="OnContinuousClick" ToolTip="连续取像"/>
                <Button Content="&#xE71A;" Style="{StaticResource PreviewIconButton}" Click="OnStopClick" ToolTip="停止取像"/>
                <Separator Margin="8,0"/>
                <TextBlock x:Name="StatusText" Foreground="{DynamicResource CameraColorTextDim}" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </StackPanel>
        </Border>
        <ui:CameraPreviewControl x:Name="Preview"/>
    </DockPanel>
</Window>
