<UserControl x:Class="VisualMaster.CameraLink.UI.CameraManagerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="#1E1E1E"
             Foreground="White"
             FontFamily="Segoe UI"
             FontSize="12"
             d:DesignHeight="640"
             d:DesignWidth="1040">
    <UserControl.Resources>
        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="MinWidth" Value="76"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinWidth" Value="34"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AFAFAF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,2,0,8"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="MinHeight" Value="26"/>
        </Style>
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="MinHeight" Value="26"/>
        </Style>
        <DataTemplate x:Key="CameraListItem">
            <Grid Margin="4,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Ellipse Width="9" Height="9" Margin="0,0,8,0" VerticalAlignment="Center">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#666666"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Fill" Value="#4DA3FF"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsGrabbing}" Value="True">
                                    <Setter Property="Fill" Value="#35D36A"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding DisplayName}" Foreground="White" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding StatusText}" Foreground="#8B8B8B" FontSize="11"/>
                </StackPanel>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="240"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0" Background="#252525">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Background="#2B2B2B" Margin="6">
                    <Button Content="扫描" Command="{Binding ScanCommand}" Style="{StaticResource DarkButton}"/>
                    <Button Content="添加" Command="{Binding AddCameraCommand}" Style="{StaticResource DarkButton}"/>
                    <Button Content="删除" Command="{Binding RemoveCameraCommand}" Style="{StaticResource DarkButton}"/>
                </StackPanel>

                <TextBlock DockPanel.Dock="Top" Text="已配置设备" Style="{StaticResource SectionLabel}" Margin="10,6,10,0"/>
                <ListBox DockPanel.Dock="Top"
                         Height="210"
                         Margin="8,0,8,8"
                         Background="#1E1E1E"
                         Foreground="White"
                         BorderBrush="#444444"
                         ItemsSource="{Binding Cameras}"
                         SelectedItem="{Binding SelectedCamera, Mode=TwoWay}"
                         ItemTemplate="{StaticResource CameraListItem}"/>

                <TextBlock DockPanel.Dock="Top" Text="扫描发现" Style="{StaticResource SectionLabel}" Margin="10,2,10,0"/>
                <ListBox Margin="8,0,8,8"
                         Background="#1E1E1E"
                         Foreground="White"
                         BorderBrush="#444444"
                         ItemsSource="{Binding DiscoveredDevices}"
                         SelectedItem="{Binding SelectedDiscovered, Mode=TwoWay}"
                         DisplayMemberPath="DisplayText"/>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#333333"/>

            <DockPanel Grid.Column="2" Background="#1E1E1E">
                <ToolBar DockPanel.Dock="Top" Background="#252525" BorderBrush="#444444">
                    <Button Content="连接" Command="{Binding ConnectCommand}" Style="{StaticResource DarkButton}"/>
                    <Button Content="断开" Command="{Binding DisconnectCommand}" Style="{StaticResource DarkButton}"/>
                    <Button Content="开始采集" Command="{Binding StartGrabbingCommand}" Style="{StaticResource DarkButton}"/>
                    <Button Content="停止采集" Command="{Binding StopGrabbingCommand}" Style="{StaticResource DarkButton}"/>
                    <Separator/>
                    <Button Content="&#xE890;" Command="{Binding OpenPreviewCommand}" Style="{StaticResource IconButton}" ToolTip="打开预览窗口"/>
                </ToolBar>

                <TabControl Margin="10" Background="#1E1E1E" BorderBrush="#444444" DataContext="{Binding SelectedCamera}">
                    <TabItem Header="设备">
                        <Grid Margin="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="名称" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}"/>
                            <TextBlock Grid.Row="1" Text="型号" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ModelName}" IsReadOnly="True" Style="{StaticResource DarkTextBox}"/>
                            <TextBlock Grid.Row="2" Text="序列号" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding AssignedSerial}" IsReadOnly="True" Style="{StaticResource DarkTextBox}"/>
                        </Grid>
                    </TabItem>

                    <TabItem Header="采集">
                        <Grid Margin="12" DataContext="{Binding ConfigVm}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="触发模式" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Row="0" Grid.Column="1" SelectedItem="{Binding TriggerMode}" ItemsSource="{Binding TriggerModes}" Style="{StaticResource DarkComboBox}"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="触发源" Style="{StaticResource FieldLabel}" Margin="18,0,8,0"/>
                            <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding TriggerSource, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsTriggerSourceEnabled}" Style="{StaticResource DarkTextBox}"/>

                            <TextBlock Grid.Row="1" Text="信号边沿" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Row="1" Grid.Column="1" SelectedItem="{Binding TriggerActivation}" ItemsSource="{Binding TriggerActivations}" IsEnabled="{Binding IsTriggerSourceEnabled}" Style="{StaticResource DarkComboBox}"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="队列容量" Style="{StaticResource FieldLabel}" Margin="18,0,8,0"/>
                            <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding FifoCapacity, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}"/>

                            <TextBlock Grid.Row="2" Text="曝光 (us)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ExposureTimeUs, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="增益" Style="{StaticResource FieldLabel}" Margin="18,0,8,0"/>
                            <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding GainRaw, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}"/>

                            <TextBlock Grid.Row="3" Text="像素格式" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding PixelFormat, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="黑白输出" Style="{StaticResource FieldLabel}" Margin="18,0,8,0"/>
                            <CheckBox Grid.Row="3" Grid.Column="3" IsChecked="{Binding MonochromeOutput}" Foreground="White" VerticalAlignment="Center"/>
                        </Grid>
                    </TabItem>

                    <TabItem Header="ROI">
                        <Grid Margin="12" DataContext="{Binding ConfigVm}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="X" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding OffsetX, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Y" Style="{StaticResource FieldLabel}" Margin="18,0,8,0"/>
                            <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding OffsetY, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}"/>
                            <TextBlock Grid.Row="1" Text="宽" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Width, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="高" Style="{StaticResource FieldLabel}" Margin="18,0,8,0"/>
                            <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding Height, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}"/>
                        </Grid>
                    </TabItem>
                </TabControl>
            </DockPanel>
        </Grid>

        <DockPanel Grid.Row="1" Background="#2B2B2B">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="0,2,6,2">
                <Button Content="保存配置" Command="{Binding SaveCommand}" Style="{StaticResource DarkButton}"/>
                <Button Content="还原" Command="{Binding RevertCommand}" Style="{StaticResource DarkButton}"/>
            </StackPanel>
            <TextBlock Text="{Binding StatusMessage}" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="10,0" TextTrimming="CharacterEllipsis"/>
        </DockPanel>
    </Grid>
</UserControl>
