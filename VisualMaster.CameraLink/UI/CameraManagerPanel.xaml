<UserControl x:Class="VisualMaster.CameraLink.UI.CameraManagerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="#1E1E1E"
             Foreground="White"
             FontFamily="Segoe UI" FontSize="12"
             d:DesignHeight="600" d:DesignWidth="900">

    <UserControl.Resources>
        <!-- 基础样式 -->
        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="MinWidth" Value="72"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4A4A4A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="MinWidth" Value="80"/>
        </Style>

        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>

        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>

        <!-- 状态指示点 -->
        <DataTemplate x:Key="CameraListItem">
            <StackPanel Orientation="Horizontal" Margin="4,3">
                <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#555555"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsGrabbing}" Value="True">
                                    <Setter Property="Fill" Value="#22DD44"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Fill" Value="#4499FF"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                <TextBlock Text=" · " Foreground="#666666" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StatusText}" Foreground="#888888" VerticalAlignment="Center" FontSize="11"/>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="160"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── 左侧：设备列表 ── -->
            <DockPanel Grid.Column="0" Background="#252525">

                <!-- 工具栏 -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                            Background="#2B2B2B" Margin="4">
                    <Button Content="扫描" Command="{Binding ScanCommand}"
                            Style="{StaticResource DarkButton}" ToolTip="扫描所有相机适配器"/>
                    <Button Content="添加" Command="{Binding AddCameraCommand}"
                            Style="{StaticResource DarkButton}" ToolTip="将选中的发现相机加入设备列表"/>
                    <Button Content="删除" Command="{Binding RemoveCameraCommand}"
                            Style="{StaticResource DarkButton}" ToolTip="从设备列表删除所选相机"/>
                </StackPanel>

                <!-- 已配置相机列表 -->
                <TextBlock DockPanel.Dock="Top" Text="已配置设备"
                           Style="{StaticResource SectionLabel}" Margin="8,4"/>
                <ListBox x:Name="CameraList"
                         DockPanel.Dock="Top"
                         Height="160"
                         Background="#1E1E1E" Foreground="White"
                         BorderBrush="#444444"
                         ItemsSource="{Binding Cameras}"
                         SelectedItem="{Binding SelectedCamera, Mode=TwoWay}"
                         ItemTemplate="{StaticResource CameraListItem}"/>

                <!-- 发现的相机列表 -->
                <TextBlock DockPanel.Dock="Top" Text="扫描发现"
                           Style="{StaticResource SectionLabel}" Margin="8,8,8,4"/>
                <ListBox
                         Background="#1E1E1E" Foreground="White"
                         BorderBrush="#444444"
                         ItemsSource="{Binding DiscoveredDevices}"
                         SelectedItem="{Binding SelectedDiscovered, Mode=TwoWay}"
                         DisplayMemberPath="DisplayText"/>
            </DockPanel>

            <!-- 分割线 -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="#333333"/>

            <!-- ── 右侧：配置面板 ── -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto"
                          Background="#1E1E1E">
                <StackPanel Margin="12,8"
                            DataContext="{Binding SelectedCamera}">

                    <!-- 设备信息 -->
                    <TextBlock Text="设备信息" Style="{StaticResource SectionLabel}"/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="名称" Style="{StaticResource FieldLabel}"/>
                        <TextBox  Grid.Row="0" Grid.Column="1" Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource DarkTextBox}"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="型号" Style="{StaticResource FieldLabel}"/>
                        <TextBox  Grid.Row="1" Grid.Column="1" Text="{Binding ModelName}" IsReadOnly="True"
                                  Style="{StaticResource DarkTextBox}"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="序列号" Style="{StaticResource FieldLabel}"/>
                        <TextBox  Grid.Row="2" Grid.Column="1" Text="{Binding AssignedSerial}" IsReadOnly="True"
                                  Style="{StaticResource DarkTextBox}"/>
                    </Grid>

                    <!-- 触发器 -->
                    <TextBlock Text="触发器" Style="{StaticResource SectionLabel}"
                               DataContext="{Binding DataContext.SelectedCamera, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    <Grid Margin="0,0,0,4"
                          DataContext="{Binding ConfigVm}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="触发模式" Style="{StaticResource FieldLabel}"/>
                        <ComboBox  Grid.Row="0" Grid.Column="1"
                                   SelectedItem="{Binding TriggerMode}"
                                   ItemsSource="{Binding TriggerModes}"
                                   Style="{StaticResource DarkComboBox}">
                        </ComboBox>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="触发源" Style="{StaticResource FieldLabel}"/>
                        <TextBox  Grid.Row="1" Grid.Column="1"
                                  Text="{Binding TriggerSource, UpdateSourceTrigger=PropertyChanged}"
                                  IsEnabled="{Binding IsTriggerSourceEnabled}"
                                  Style="{StaticResource DarkTextBox}"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="信号边沿" Style="{StaticResource FieldLabel}"/>
                        <ComboBox  Grid.Row="2" Grid.Column="1"
                                   SelectedItem="{Binding TriggerActivation}"
                                   ItemsSource="{Binding TriggerActivations}"
                                   IsEnabled="{Binding IsTriggerSourceEnabled}"
                                   Style="{StaticResource DarkComboBox}" />
                    </Grid>

                    <!-- 图像参数 -->
                    <TextBlock Text="图像参数" Style="{StaticResource SectionLabel}"
                               DataContext="{Binding DataContext.SelectedCamera, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    <Grid Margin="0,0,0,4"
                          DataContext="{Binding ConfigVm}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="曝光 (μs)" Style="{StaticResource FieldLabel}"/>
                        <TextBox  Grid.Row="0" Grid.Column="1"
                                  Text="{Binding ExposureTimeUs, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource DarkTextBox}"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="增益" Style="{StaticResource FieldLabel}"/>
                        <TextBox  Grid.Row="1" Grid.Column="1"
                                  Text="{Binding GainRaw, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource DarkTextBox}"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="像素格式" Style="{StaticResource FieldLabel}"/>
                        <TextBox  Grid.Row="2" Grid.Column="1"
                                  Text="{Binding PixelFormat, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource DarkTextBox}"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="黑白输出" Style="{StaticResource FieldLabel}"/>
                        <CheckBox  Grid.Row="3" Grid.Column="1"
                                   IsChecked="{Binding MonochromeOutput}"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- ROI 配置 -->
                    <TextBlock Text="ROI 配置" Style="{StaticResource SectionLabel}"
                               DataContext="{Binding DataContext.SelectedCamera, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    <Grid Margin="0,0,0,4"
                          DataContext="{Binding ConfigVm}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="X" Style="{StaticResource FieldLabel}" MinWidth="28"/>
                        <TextBox  Grid.Row="0" Grid.Column="1" Text="{Binding OffsetX, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Y" Style="{StaticResource FieldLabel}" MinWidth="28" Margin="8,0,6,0"/>
                        <TextBox  Grid.Row="0" Grid.Column="3" Text="{Binding OffsetY, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="宽" Style="{StaticResource FieldLabel}" MinWidth="28"/>
                        <TextBox  Grid.Row="1" Grid.Column="1" Text="{Binding Width, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="高" Style="{StaticResource FieldLabel}" MinWidth="28" Margin="8,0,6,0"/>
                        <TextBox  Grid.Row="1" Grid.Column="3" Text="{Binding Height, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}"/>
                    </Grid>

                    <!-- 采集队列 -->
                    <TextBlock Text="采集队列" Style="{StaticResource SectionLabel}"
                               DataContext="{Binding DataContext.SelectedCamera, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
                                DataContext="{Binding ConfigVm}">
                        <TextBlock Text="队列容量" Style="{StaticResource FieldLabel}"/>
                        <TextBox Width="60" Text="{Binding FifoCapacity, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}"/>
                    </StackPanel>

                    <!-- 操作按钮 -->
                    <Separator Background="#444444" Margin="0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="连接"     Command="{Binding DataContext.ConnectCommand,        RelativeSource={RelativeSource AncestorType=UserControl}}" Style="{StaticResource DarkButton}"/>
                        <Button Content="断开"     Command="{Binding DataContext.DisconnectCommand,     RelativeSource={RelativeSource AncestorType=UserControl}}" Style="{StaticResource DarkButton}"/>
                        <Button Content="开始采集" Command="{Binding DataContext.StartGrabbingCommand,  RelativeSource={RelativeSource AncestorType=UserControl}}" Style="{StaticResource DarkButton}"/>
                        <Button Content="停止采集" Command="{Binding DataContext.StopGrabbingCommand,   RelativeSource={RelativeSource AncestorType=UserControl}}" Style="{StaticResource DarkButton}"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- 底部状态栏 + 保存/还原 -->
        <DockPanel Grid.Row="1" Background="#2B2B2B" Margin="0,4,0,0">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="保存配置" Command="{Binding SaveCommand}"
                        Style="{StaticResource DarkButton}"/>
                <Button Content="还原"     Command="{Binding RevertCommand}"
                        Style="{StaticResource DarkButton}"/>
            </StackPanel>
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#AAAAAA" VerticalAlignment="Center"
                       Margin="8,0" TextTrimming="CharacterEllipsis"/>
        </DockPanel>
    </Grid>
</UserControl>
