<UserControl x:Class="VisualMaster.CameraLink.UI.CameraImageViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#202020"
             Focusable="True">
    <Grid x:Name="Root" ClipToBounds="True"
          MouseWheel="OnMouseWheel"
          MouseRightButtonUp="OnMouseRightButtonUp">
        <Canvas x:Name="ImageLayer" Background="#202020" ClipToBounds="True">
            <Border x:Name="ImageBounds"
                    Background="#2B2B2B"
                    Width="1"
                    Height="1"
                    MouseLeftButtonDown="OnImageMouseLeftButtonDown"
                    MouseLeftButtonUp="OnImageMouseLeftButtonUp"
                    MouseMove="OnImageMouseMove">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="ScaleTransform"/>
                        <TranslateTransform x:Name="TranslateTransform"/>
                    </TransformGroup>
                </Border.RenderTransform>
                <Image x:Name="ImageHost"
                       Stretch="Fill"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
            </Border>
        </Canvas>

        <Border x:Name="Toolbar"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Background="#CC242424"
                BorderBrush="#555555"
                BorderThickness="1"
                CornerRadius="3"
                Margin="8"
                Padding="4">
            <StackPanel Orientation="Horizontal">
                <Button Content="&#xE9A6;" FontFamily="Segoe MDL2 Assets" Width="32" Height="28" Margin="2" Click="OnFitClick" ToolTip="适合窗口"/>
                <Button Content="1:1" Width="42" Height="28" Margin="2" Click="OnActualSizeClick" ToolTip="1:1 像素"/>
                <Button Content="&#xE74E;" FontFamily="Segoe MDL2 Assets" Width="32" Height="28" Margin="2" Click="OnSaveClick" ToolTip="保存图像"/>
            </StackPanel>
        </Border>

        <Border HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Background="#CC242424"
                BorderBrush="#555555"
                BorderThickness="1"
                CornerRadius="3"
                Margin="8"
                Padding="6,3">
            <TextBlock x:Name="InfoText" Foreground="#E6E6E6"/>
        </Border>

        <Canvas x:Name="Navigator"
                Width="120"
                Height="90"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="8"
                Background="#AA202020">
            <Rectangle x:Name="NavigatorImage"
                       Stroke="White"
                       StrokeThickness="1"
                       Fill="#20FFFFFF"/>
            <Rectangle x:Name="NavigatorViewport"
                       Stroke="#FFD800"
                       StrokeThickness="2"/>
        </Canvas>
    </Grid>
</UserControl>
