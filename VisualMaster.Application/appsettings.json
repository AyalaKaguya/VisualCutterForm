{
  "Application": {
    "Environment": "Production",
    "Profile": "Default",
    "Shell": "Wpf",
    "Theme": "Dark"
  },
  "Modules": {
    "Camera": true,
    "Communication": true,
    "Operators": true,
    "Plugins": true
  },
  "Paths": {
